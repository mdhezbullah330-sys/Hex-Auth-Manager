# Copy this file to .env and fill in the values

# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://user:password@host:27017/dbname?ssl=true&authSource=admin

# ─── Auth ────────────────────────────────────────────────────────────────────
SESSION_SECRET=your-very-long-random-secret-key-here

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─── SMTP / Email ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_FROM=Hex Auth <noreply@yourdomain.com>
SMTP_PASS=your-smtp-api-key-here

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
